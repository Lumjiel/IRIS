# IRIS 生产环境配置
# 复制为 .env 并填入真实值

# === 必填 ===
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
TAVILY_API_KEY=tvly-xxxxxxxx
DASHSCOPE_API_KEY=sk-xxxxxxxx

# === 安全 ===
# 生产环境必须设置为你的域名，不要用 *
CORS_ORIGINS=https://your-domain.com

# === 模型 ===
LLM_MODEL_PRIMARY=qwen3.7-plus
LLM_MODEL_FALLBACK=deepseek-v4-flash
LLM_TIMEOUT_FAST=60
LLM_TIMEOUT_SMART=90
MAX_REVISIONS=3

# === RAG ===
# 2G 服务器不要开，省 400MB 内存
ENABLE_RERANKER=false
CHUNK_SIZE=500
TOP_K=5

# === 搜索 ===
TAVILY_MAX_RESULTS=3
TAVILY_MAX_RETRIES=2

# === 服务器 ===
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=info
