# IRIS 生产环境配置
# 复制为 .env 并填入真实值

# === 必填 ===
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
TAVILY_API_KEY=tvly-xxxxxxxx
DASHSCOPE_API_KEY=sk-xxxxxxxx

# === 安全 ===
# 生产环境必须设置为你的域名，不要用 *
CORS_ORIGINS=https://your-domain.com

# === 模型 ===
LLM_MODEL_PRIMARY=qwen3.7-plus
LLM_MODEL_FALLBACK=deepseek-v4-flash
LLM_TIMEOUT_FAST=60
LLM_TIMEOUT_SMART=90
MAX_REVISIONS=3

# 按节点分配模型（可选，未配置回退到 PRIMARY）
# 按到期时间排序：7月到期用轻量节点，9月到期留关键节点
LLM_MODEL_ROUTER=qwen3.6-flash        # 意图分类，轻量
LLM_MODEL_PLANNER=qwen3.6-flash       # 拆子查询
LLM_MODEL_RESEARCHER=deepseek-v4-flash # 二分类判断
LLM_MODEL_WRITER=qwen3.7-plus         # 报告生成，需质量
LLM_MODEL_REVIEWER=deepseek-v4-pro     # 质量审核，需强推理
LLM_MODEL_REFINER=qwen3.6-plus         # 文本修订

# === RAG ===
# 2G 服务器不要开，省 400MB 内存
ENABLE_RERANKER=false
CHUNK_SIZE=500
TOP_K=5

# === 搜索 ===
TAVILY_MAX_RESULTS=3
TAVILY_MAX_RETRIES=2

# === 服务器 ===
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=info

# === 数据目录 ===
# Docker 部署时改为 /data/iris
CREATION_DIR=/path/to/creation/dir
CHECKPOINT_DB=/data/iris/checkpoints.db
DATA_DIR=/data/iris
